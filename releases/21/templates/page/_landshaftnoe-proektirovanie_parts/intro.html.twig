{% embed "_parts/headers/image_text_inside.html.twig" with {
    img: "/img/main_bg.jpg",
    overlay_color: "rgba(200, 223, 192, 0.18)"
} %}
    {% block body %}
        {# Единый hero для всех экранов: текст поверх изображения #}
        <div class="flex h-[460px] sm:h-[500px] md:h-[560px] lg:h-[850px] xl:h-[950px] 2xl:h-[1050px] items-center lp-hero-desktop">
            <div class="max-w-4xl px-4 sm:px-8 sm:py-6 md:px-10 md:py-7" style="font-family: 'Articulat CF', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif; color: #F3F7EF; text-shadow: 0 2px 14px rgba(0, 0, 0, 0.45);">
                <h1 class="text-2xl sm:text-3xl md:text-[28px] lg:text-[40px] 2xl:text-[48px] leading-tight font-normal mb-4 sm:mb-5 2xl:mb-6">
                    Ландшафтное проектирование в СПБ
                </h1>
                <p class="text-sm sm:text-base 2xl:text-lg leading-relaxed mb-4 sm:mb-5 2xl:mb-6 max-w-3xl">
                    Ландшафтное проектирование — это не роскошь, а разумное вложение,
                    которое позволяет создать красивый, функциональный и, что самое главное,
                    жизнеспособный сад в сложных северных условиях.
                </p>

                <div class="inline-flex flex-col gap-2 w-full sm:w-auto">
                    <button class="inline-flex items-center justify-center w-full sm:w-auto px-8 py-2.5 bg-[#7D9B73] text-white text-sm sm:text-base font-bold">
                        Рассчитать стоимость
                    </button>
                    <div class="text-[11px] sm:text-xs text-[#F3F7EF]">
                        Бесплатная консультация и расчёт стоимости проекта
                    </div>
                </div>
            </div>
        </div>
    {% endblock %}
{% endembed %}
