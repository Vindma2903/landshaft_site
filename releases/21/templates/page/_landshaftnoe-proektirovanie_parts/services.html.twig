    {# Комплекс работ ландшафтного бюро #}
    <div>
        <h2 class="text-3xl lg:text-4xl uppercase mb-8">Комплекс работ ландшафтного бюро</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% set worksCards = [
                {title: "Мощение дорожек", img: "/img/landscaping-img (1).png"},
                {title: "Подпорные стены", img: "/img/retaining_walls.png"},
                {title: "Озеленение", img: "/img/landscaping-img (1).png"},
                {title: "Очистка прудов", img: "/img/cleaning_ponds_img.png"},
                {title: "Благоустройство", img: "/img/paving_paths_img.png"},
                {title: "Уход за садом", img: "/img/garden_maintenance_img.png"},
            ] %}

            {% for card in worksCards %}
                <article class="group overflow-hidden border border-gray-700">
                    <div class="relative aspect-[4/3] bg-cover bg-center bg-no-repeat group-hover:scale-[1.02] transition-transform duration-300"
                         style="background-image: url('{{ card.img }}')">
                        <div class="absolute left-4 bottom-4">
                            <h3 class="text-lg font-medium" style="color: #111111;">
                                {{ card.title }}
                            </h3>
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>

