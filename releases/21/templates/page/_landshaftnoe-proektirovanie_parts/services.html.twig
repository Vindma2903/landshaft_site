        <div class="px-4 sm:px-6 lg:px-10 py-6 border-b border-gray-700">
            <h2 class="text-2xl sm:text-3xl lg:text-4xl 2xl:text-[44px] uppercase">Почему выбирают нас</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
            <article class="px-4 sm:px-6 lg:px-10 py-6 border-b md:border-b-0 md:border-r border-gray-700 flex gap-4">
